# Rust ----------------------------------------------------------------
# Compiled artifacts. Cargo.lock files are committed (root + every
# subcrate compiles to a binary or cdylib, so reproducible builds matter).
target/
**/target/
*.rs.bk

# Node ----------------------------------------------------------------
node_modules/
# napi-rs build outputs (regenerated by `npx napi build`).
node/index.node
node/index.d.ts
*.node

# Python --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Native extension binaries built by maturin / setuptools.
*.so
*.pyd

# Editors / IDEs ------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.\#*
\#*\#

# OS ------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# Per-user tool state -------------------------------------------------
.claude/

# Misc test scratch ---------------------------------------------------
*.nosqlite
*.nosqlite-journal
*.nosqlite-shm
*.nosqlite-wal
